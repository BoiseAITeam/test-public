# ============================================================
# InsureTrack — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ----- Supabase / PostgreSQL --------------------------------
# Use the CONNECTION POOLER string from Supabase:
#   Project Settings → Database → Connection Pooling
#   Mode: Transaction  |  Port: 6543
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ----- JWT --------------------------------------------------
# At least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ----- Server -----------------------------------------------
PORT=3001
NODE_ENV=development
